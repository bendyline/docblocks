{
  "name": "docblocks",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "all": "npm install && npm run build && npm run lint && npm run format:check && npm run typecheck && npm test",
    "build": "npm run build:core && npm run build:react && npm run build:cli && npm run build:vscode",
    "build:core": "npm run build -w @bendyline/docblocks",
    "build:react": "npm run build -w @bendyline/docblocks-react",
    "build:cli": "npm run build -w @bendyline/docblocks-cli",
    "build:vscode": "npm run build -w docblocks-vscode",
    "test": "mocha",
    "test:e2e": "playwright test",
    "test:e2e:vscode": "npm run test:e2e -w docblocks-vscode",
    "site": "npm run build && npm run dev -w docblocks-site",
    "dev": "npm run dev -w docblocks-site",
    "typecheck": "tsc -b packages/core packages/react packages/cli",
    "clean": "rimraf packages/*/dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prettierfix": "prettier --write .",
    "format:check": "prettier --check .",
    "link:squisq": "tsx scripts/link-squisq.ts",
    "unlink:squisq": "npm unlink --no-save @bendyline/squisq @bendyline/squisq-react @bendyline/squisq-editor-react @bendyline/squisq-formats @bendyline/squisq-video @bendyline/squisq-video-react && npm install",
    "release": "multi-semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "chai": "6.2.2",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-sonarjs": "4.0.2",
    "globals": "15.15.0",
    "mocha": "11.7.5",
    "multi-semantic-release": "3.1.0",
    "prettier": "3.8.1",
    "rimraf": "5.0.10",
    "semantic-release": "25.0.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  }
}
