{
  "name": "docblocks-vscode",
  "displayName": "DocBlocks",
  "description": "DocBlocks markdown editor powered by Squisq",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "bendyline",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/docblocks.git",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.web.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "docblocks.openEditor",
        "title": "DocBlocks: Open Editor",
        "category": "DocBlocks"
      },
      {
        "command": "docblocks.openInDocBlocks",
        "title": "Open in DocBlocks",
        "category": "DocBlocks"
      },
      {
        "command": "docblocks.openSetup",
        "title": "DocBlocks: Open Setup",
        "category": "DocBlocks"
      }
    ],
    "customEditors": [
      {
        "viewType": "docblocks.markdownEditor",
        "displayName": "DocBlocks Editor",
        "selector": [
          {
            "filenamePattern": "**/*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "docblocks.openInDocBlocks",
          "when": "resourceExtname == .md",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "docblocks.openInDocBlocks",
          "when": "resourceExtname == .md",
          "group": "1_open"
        }
      ],
      "commandPalette": [
        {
          "command": "docblocks.openInDocBlocks",
          "when": "resourceExtname == .md"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docblocks",
          "title": "DocBlocks",
          "icon": "resources/docblocks-icon.svg"
        }
      ]
    },
    "views": {
      "docblocks": [
        {
          "id": "docblocks.setupView",
          "name": "Setup",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup && npm run build:webview",
    "build:webview": "vite build --config webview/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test:web": "vscode-test-web --extensionDevelopmentPath=. --browser=none --port=3100",
    "test:e2e": "npm run build && playwright test --config=e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@types/vscode": "1.110.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vscode/test-web": "0.0.80",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "6.4.1"
  }
}
