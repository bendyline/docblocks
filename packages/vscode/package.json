{
  "name": "docblocks-vscode",
  "displayName": "DocBlocks",
  "description": "DocBlocks markdown editor powered by Squisq",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "bendyline",
  "private": true,
  "repository": {
    "type": "git",
