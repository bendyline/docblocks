{
  "name": "@bendyline/docblocks-react",
  "version": "0.1.0",
  "description": "React components for DocBlocks — file explorer, workspace picker, and editor shell",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/docblocks.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/bendyline/docblocks",
  "keywords": [
    "docblocks",
    "react",
    "markdown",
    "file-explorer",
    "editor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./src/styles/docblocks.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/docblocks": "0.1.0",
    "@bendyline/squisq": "1.2.1",
    "@bendyline/squisq-editor-react": "1.2.1",
    "@bendyline/squisq-formats": "1.2.1",
    "@bendyline/squisq-react": "1.1.1",
    "@bendyline/squisq-video": "1.0.3",
    "@bendyline/squisq-video-react": "1.0.3",
    "monaco-editor": "0.55.1"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
